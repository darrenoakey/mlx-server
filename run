#!/usr/bin/env python3
import argparse
import subprocess
import sys
from pathlib import Path

TEST_OUT = Path("output/testing")


# ##################################################################
# run shell
# executes a shell command and returns exit code
def _run(cmd: list[str]) -> int:
    return subprocess.call(cmd)


# ##################################################################
# test command
# runs pytest for a specific test target, logging output
def command_test(args: argparse.Namespace) -> int:
    TEST_OUT.mkdir(parents=True, exist_ok=True)
    target = args.target
    log_name = target.replace("/", "_").replace("::", "_") + ".log"
    log_path = TEST_OUT / log_name
    with open(log_path, "w") as log_file:
        result = subprocess.call(
            ["pytest", "-q", target, "--maxfail=1", "--disable-warnings"],
            stdout=log_file,
            stderr=subprocess.STDOUT,
        )
    return result


# ##################################################################
# lint command
# runs ruff linter with line length 120
def command_lint(_: argparse.Namespace) -> int:
    return _run(["ruff", "check", "--line-length", "120", "src/"])


# ##################################################################
# format command
# runs ruff formatter
def command_format(_: argparse.Namespace) -> int:
    return _run(["ruff", "format", "src/"])


# ##################################################################
# check command
# runs full test suite and quality gates
def command_check(_: argparse.Namespace) -> int:
    lint_result = _run(["ruff", "check", "--line-length", "120", "src/"])
    if lint_result != 0:
        print("Lint check failed")
        return lint_result
    test_result = _run(["pytest", "-q", "src/", "--disable-warnings"])
    if test_result != 0:
        print("Tests failed")
        return test_result
    print("All checks passed")
    return 0


# ##################################################################
# serve command
# starts the mlx server
def command_serve(args: argparse.Namespace) -> int:
    port = args.port if hasattr(args, "port") and args.port else 11435
    return _run([
        "uvicorn",
        "src.server:app",
        "--host", "0.0.0.0",
        "--port", str(port),
    ])


# ##################################################################
# main
# parses arguments and dispatches to appropriate command
def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="MLX Server - Ollama-compatible server for MLX models"
    )
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_test = sub.add_parser("test", help="Run a single test target")
    p_test.add_argument("target", help="e.g. src/server_test.py::test_tags")
    p_test.set_defaults(func=command_test)

    p_lint = sub.add_parser("lint", help="Run linter")
    p_lint.set_defaults(func=command_lint)

    p_format = sub.add_parser("format", help="Format code")
    p_format.set_defaults(func=command_format)

    p_check = sub.add_parser("check", help="Run full suite and gates")
    p_check.set_defaults(func=command_check)

    p_serve = sub.add_parser("serve", help="Start the MLX server")
    p_serve.add_argument("--port", "-p", type=int, default=11435, help="Port to listen on")
    p_serve.set_defaults(func=command_serve)

    args = parser.parse_args(argv)
    return args.func(args)


# ##################################################################
# entry point
# standard python dispatch
if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
